  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "set VITE_DEV_HTTPS=true&& vite --port=3000 --host=0.0.0.0",
    "dev:http": "set VITE_DEV_HTTPS=false&& vite --port=3000 --host=0.0.0.0",
    "dev:https": "set VITE_DEV_HTTPS=true&& vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "preview:mobile": "vite preview --host=0.0.0.0 --port=3000",
    "deploy:gcp": "powershell -NoProfile -ExecutionPolicy Bypass -File ./server/deploy_cloud_run.ps1",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test:mobile:permission": "node test/mobile_permission_regression_suite.mjs",
    "test:audio:unit": "tsx --test test/audio_focus.unit.mts",
    "test:audio:integration": "node test/audio_dual_voice.chrome.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "gifenc": "^1.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.35.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "autoprefixer": "^10.4.21",
    "playwright": "^1.58.2",
    "selfsigned": "^5.5.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
